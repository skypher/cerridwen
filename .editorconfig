root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{html,css,js,json,yml,yaml,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
# Markdown gets a pass on trailing whitespace because two trailing
# spaces are a meaningful line break.
trim_trailing_whitespace = false
